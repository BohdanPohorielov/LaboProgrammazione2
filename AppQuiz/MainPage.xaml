<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AppQuiz.MainPage">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="18">

            
            <Label
                x:Name="ScoreLabel"
                Text="Punteggio: 0"
                FontSize="22"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="{StaticResource Primary}" />

            
            <Label
                x:Name="QuestionTextLabel"
                Text="Caricamento domanda..."
                FontSize="24"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="Black" />

            
            <Label
                x:Name="DomandaLabel"
                Text="DOMANDA"
                FontSize="12"
                TextColor="Gray"
                HorizontalOptions="Center" />

            
            <Grid
                ColumnDefinitions="*,*"
                Margin="0,10,0,10">

                <Entry 
                    x:Name="DomandaEnt"
                    Placeholder="Inserisci la risposta"
                    IsVisible="False"
                    Grid.Column="0"/>
               
                <Button
                     x:Name="DomandaBtn"
                     Grid.Column="1"
                     Text="Inviare la risposta"
                     Clicked="OnAnswer_Clicked"
                     CommandParameter="Entry"
                     FontSize="18"
                     BackgroundColor="#284192"
                     CornerRadius="19"
                     WidthRequest="110"
                     HeightRequest="70"
                 IsVisible="False"/>




                <Button
                    x:Name="TrueButton"
                    Grid.Column="0"
                    Text="Vero"
                    Clicked="OnAnswer_Clicked"
                    CommandParameter="true"
                    FontSize="18"
                    BackgroundColor="#235562"
                    CornerRadius="19"
                    WidthRequest="110"
                    HeightRequest="70"
                    IsVisible="False"/>


                <Button
                    x:Name="FalseButton"
                    Grid.Column="1"
                    Text="Falso"
                    Clicked="OnAnswer_Clicked"
                    CommandParameter="false"
                    FontSize="18"
                    BackgroundColor="#cc5562"
                    CornerRadius="19"
                    WidthRequest="110"
                    HeightRequest="70"
                    IsVisible="False"/>

            </Grid>


            <Button
                x:Name="Resetbtn"
                Text="Reset"
                Clicked="Resetbtn_Clicked"
                FontSize="18"
                BackgroundColor="#FF00FF"
                CornerRadius="19"
                WidthRequest="110"
                HeightRequest="70"/>


            <Button
                x:Name="btnResult"
                Text="Vai a risultati"
                Clicked="btnResult_Clicked"
                WidthRequest="110"
                HeightRequest="70"
                IsVisible="False"
                HorizontalOptions="Center"/>

            <Button
                x:Name="btnHint"
                Text="Hint"
                Clicked="btnHint_Clicked"
                WidthRequest="110"
                HeightRequest="70"
                HorizontalOptions="Center"/>

            <Label 
                x:Name="LblHint"
                Text="Hint"
                FontSize="15"
                BackgroundColor="#ddd"
                WidthRequest="250"
                HeightRequest="125"
                HorizontalTextAlignment="Center"
                VerticalTextAlignment="Center"
                HorizontalOptions="Center"
                IsVisible="Hidden">
            </Label>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>